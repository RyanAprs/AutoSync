generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum AppRole {
  admin
  project_manager
  designer
  finance
  director
}

enum BoardRole {
  owner
  editor
  viewer
}

enum SubmissionStatus {
  pending
  approved
  revision_requested
}

enum PaymentStatus {
  draft
  verified
  completed
}

enum NotificationType {
  board_invite
  task_assigned
  task_deadline_reminder
  design_submission
  revision_requested
  design_approved
  comment_on_task
  payment_verified
  payment_completed
}

// ─── User & Auth ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  passwordHash  String?   @map("password_hash")
  role          AppRole   @default(designer)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  boardMembers     BoardMember[]
  assignedCards    Card[]              @relation("CardAssignee")
  cardComments     CardComment[]
  designSubmissions DesignSubmission[]
  designerPoints   DesignerPoint[]
  payments         Payment[]
  notifications    Notification[]
  revisionsRequested Revision[]        @relation("RevisionRequester")
  revisionsResponded Revision[]        @relation("RevisionResponder")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Boards & Members ──────────────────────────────────────────────────────

model Board {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members  BoardMember[]
  columns  Column[]
}

model BoardMember {
  id        String    @id @default(cuid())
  boardId   String    @map("board_id")
  userId    String    @map("user_id")
  role      BoardRole @default(editor)
  invitedAt DateTime @default(now()) @map("invited_at")
  acceptedAt DateTime? @map("accepted_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
  @@index([boardId])
}

// ─── Kanban: Columns & Cards ────────────────────────────────────────────────

model Column {
  id       String   @id @default(cuid())
  boardId  String   @map("board_id")
  title    String
  position Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
  @@index([boardId, position])
}

model Card {
  id          String    @id @default(cuid())
  columnId    String    @map("column_id")
  title       String
  description String?   @db.Text
  position    Int       @default(0)
  deadline    DateTime? @db.Date
  assigneeId  String?   @map("assignee_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  column       Column              @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee     User?               @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments     CardComment[]
  attachments  CardAttachment[]
  submissions  DesignSubmission[]

  @@index([columnId])
  @@index([columnId, position])
  @@index([assigneeId])
}

model CardComment {
  id        String   @id @default(cuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model CardAttachment {
  id        String   @id @default(cuid())
  cardId    String   @map("card_id")
  name      String
  s3Key     String   @map("s3_key")
  mimeType  String?  @map("mime_type")
  sizeBytes Int?     @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

// ─── Design submissions & revisions ─────────────────────────────────────────

model DesignSubmission {
  id        String           @id @default(cuid())
  cardId    String           @map("card_id")
  submittedById String        @map("submitted_by_id")
  status    SubmissionStatus @default(pending)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  reviewedAt DateTime?       @map("reviewed_at")
  reviewedById String?       @map("reviewed_by_id")

  card       Card             @relation(fields: [cardId], references: [id], onDelete: Cascade)
  submittedBy User            @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  files      SubmissionFile[]
  revisions  Revision[]
  designerPoint DesignerPoint?

  @@index([cardId])
  @@index([submittedById])
}

model SubmissionFile {
  id             String   @id @default(cuid())
  submissionId   String   @map("submission_id")
  name           String
  s3Key          String   @map("s3_key")
  mimeType       String?  @map("mime_type")
  sizeBytes      Int?     @map("size_bytes")
  createdAt      DateTime @default(now()) @map("created_at")

  submission DesignSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model Revision {
  id           String   @id @default(cuid())
  submissionId String   @map("submission_id")
  requestedById String  @map("requested_by_id")
  comment      String   @db.Text
  respondedById String? @map("responded_by_id")
  respondedAt  DateTime? @map("responded_at")
  createdAt    DateTime @default(now()) @map("created_at")

  submission   DesignSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  requestedBy  User             @relation("RevisionRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  respondedBy User?            @relation("RevisionResponder", fields: [respondedById], references: [id], onDelete: SetNull)

  @@index([submissionId])
}

// ─── Designer points & payments ─────────────────────────────────────────────

model DesignerPoint {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  points        Int      // e.g. +5 per approved design
  submissionId  String?  @unique @map("submission_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission  DesignSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model Payment {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  period       String        // e.g. "2025-03"
  totalPoints  Int           @map("total_points")
  bonusPoints  Int?          @default(0) @map("bonus_points")
  pricePerPoint Decimal?     @map("price_per_point") @db.Decimal(10, 4)
  amount       Decimal?      @db.Decimal(12, 2)
  status       PaymentStatus @default(draft)
  verifiedAt   DateTime?     @map("verified_at")
  completedAt  DateTime?     @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
  @@index([status])
}

// ─── Notifications ─────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}
